# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# ─── Jira (Atlassian Cloud) ───────────────────────────────────────────────────
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://nirvana-team.atlassian.net
JIRA_EMAIL=you@nirvanatech.com
JIRA_TOKEN=

# ─── Salesforce ───────────────────────────────────────────────────────────────
# Get the security token by emailing yourself: SFDC → Settings → Reset My Security Token.
# Use SFDC_DOMAIN=test for a sandbox org, "login" for production (default).
SFDC_USERNAME=you@nirvanatech.com
SFDC_PASSWORD=
SFDC_SECURITY_TOKEN=
SFDC_DOMAIN=login

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
